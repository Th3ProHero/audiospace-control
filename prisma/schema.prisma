generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  storageUsed  Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  audioSources AudioSource[]
  profiles     Profile[]
}

model Profile {
  id             String          @id @default(cuid())
  userId         String
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleBlocks ScheduleBlock[]

  @@index([userId])
}

model AudioSource {
  id             String          @id @default(cuid())
  userId         String
  type           String
  name           String
  urlOrPath      String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleBlocks ScheduleBlock[]

  @@index([userId])
  @@index([type])
}

model ScheduleBlock {
  id            String      @id @default(cuid())
  profileId     String
  audioSourceId String
  startTime     DateTime
  endTime       DateTime
  blockType     String      @default("MUSIC")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  audioSource   AudioSource @relation(fields: [audioSourceId], references: [id], onDelete: Cascade)
  profile       Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}
